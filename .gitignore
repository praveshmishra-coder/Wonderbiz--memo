# =============================================
#   Wonderbiz Memories — .gitignore
# =============================================

# ── Environment Variables ─────────────────────
.env
.env.local
.env.development
.env.production
.env.test

# ── Node Modules ──────────────────────────────
node_modules/
*/node_modules/

# ── Uploaded Files (user media) ───────────────
server/uploads/

# ── React Build Output ────────────────────────
client/build/
client/.env.local
client/.env.development.local
client/.env.test.local
client/.env.production.local

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS Files ──────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / IDE ──────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ──────────────────────────────────────
.cache/
.parcel-cache/
dist/
coverage/
