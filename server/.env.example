# =============================================
#   Wonderbiz Memories — Server Environment
# =============================================

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/wonderbiz?retryWrites=true&w=majority

# Server port (optional, defaults to 5000)
PORT=5000
